    {
      "class": "com.framed.cdss.actors.RespiratoryRateEstimationActor",
      "id": "RespiratoryRateEstimator",
      "etco2Channel":"RealTime.Oxylog-3000-Plus-00.CO2 concentration, CO2 (mmHg).parsed",
      "outputChannels": [
        "EstimatedRR"
      ],
      "windowSize": 20,
      "riseSlopeMin": 0.1,
      "fallSlopeMin": 0.1,
      "minBreathIntervalSec": 1,
      "historySeconds": 10,
      "useEMA": true,
      "emaAlpha": 0.5,
      "useHampel": true,
      "hampelWindow": 5,
      "hampelK": 3
    },
    {
      "class": "com.framed.cdss.actors.RRMismatchClassificationActor",
      "id": "RRMismatchClassifier",
      "rrEstimationChannel": "EstimatedRR",
