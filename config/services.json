      "limits": {
        "Measurement.Oxylog-3000-Plus-00.End-tidal CO2 concentration, etCO2.parsed": [0,25,30,40]
      }
    },
    {
      "class": "com.framed.cdss.actors.LimitClassificationActor",
      "id": "PulseOxi-Limit-Classifier",
